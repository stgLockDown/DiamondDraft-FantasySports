# ─── Database ───────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/diamonddraft

# ─── Authentication ─────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this

# ─── Server ─────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# ─── CORS ───────────────────────────────────────────────────────
# In production, set this to your actual origins (comma-separated).
# Using "*" is tolerated but not recommended once you ship.
# e.g. https://diamonddraft-production.up.railway.app,https://valorodds.com
CORS_ORIGIN=*

# ─── Stripe (optional) ──────────────────────────────────────────
STRIPE_SECRET_KEY=

# ─── ValorOdds cross-platform integration ───────────────────────
# Shared HS256 secret between valorodds.com and diamonddraft.app.
# MUST be identical on both servers. Generate: openssl rand -base64 64
VALORODDS_SSO_SECRET=

# Base URL of the ValorOdds API. Used to proxy injury / news feeds into
# DiamondDraft player pages. Leave blank to disable the proxy.
# e.g. https://valorodds.com or https://valorodds-production.up.railway.app
VALORODDS_API_URL=

# Which ValorOdds tiers grant DiamondDraft PRO for free (comma-separated).
VALORODDS_PRO_TIERS=beta,premium,vip

# Which ValorOdds tiers additionally grant Commissioner+ (comma-separated).
VALORODDS_COMMISSIONER_TIERS=vip