# ─── Database ──────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/diamonddraft

# ─── Authentication ────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this

# ─── Server ────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# ─── CORS ──────────────────────────────────────────────────────
# In production with single-container deploy, set to your Railway domain
# e.g., https://diamonddraft-production.up.railway.app
CORS_ORIGIN=*